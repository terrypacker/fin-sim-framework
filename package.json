{
  "name": "@terrypacker/financial-sim",
  "version": "1.0.0-alpha.1",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build:index": "node scripts/build-index.js",
    "build": "rollup -c",
    "test": "node --test $(find tests -name '*.test.mjs' ! -name 'timeline-view.test.mjs' ! -name 'balance-chart-view.test.mjs' ! -name 'time-controls.test.mjs')",
    "test:viz": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs",
    "build:watch": "rollup -c -w",
    "dev": "npm run clean && rollup -c -w"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.2",
    "@rollup/plugin-terser": "^1.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "rollup": "^4.60.2",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-copy-watch": "^0.0.1",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-serve": "^3.0.0"
  }
}
